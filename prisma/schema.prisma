generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ─── COMPANY ─────────────────────────────────────────────────────────────────
model Company {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  website   String?
  address   String?
  city      String?
  state     String?
  zip       String?
  country   String   @default("US")
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                   User[]
  clients                 Client[]
  vendors                 Vendor[]
  quotes                  Quote[]
  salesOrders             SalesOrder[]
  purchaseOrders          PurchaseOrder[]
  catalogItems            CatalogItem[]
  settings                CompanySettings?
  distributorIntegrations DistributorIntegration[]
  microsoftConnections    MicrosoftConnection[]
  approvalWorkflows       ApprovalWorkflow[]
  roles                   Role[]
}

// ─── COMPANY SETTINGS ────────────────────────────────────────────────────────
model CompanySettings {
  id        String  @id @default(cuid())
  companyId String  @unique
  company   Company @relation(fields: [companyId], references: [id])

  // Quote settings
  quotePrefix               String               @default("Q")
  quoteExpiryDays           Int                  @default(30)
  quoteTerms                String?              @db.Text
  quoteDefaultCc            String?
  quoteApprovalThreshold    Float?
  quoteSendFromMode         String               @default("CREATOR")
  quoteSendFromConnectionId String?
  quoteSendFromConnection   MicrosoftConnection? @relation(fields: [quoteSendFromConnectionId], references: [id])

  // SO/PO settings
  soPrefix             String @default("SO")
  poPrefix             String @default("PO")
  poDefaultPaymentType String @default("Net30")
  // Per-status notify rule: { READY_TO_INVOICE: { type: "user"|"role", id }, READY_TO_ORDER: {...}, READY_TO_CLOSEOUT: {...} }
  soStatusNotifyRules  Json?

  // Branding
  primaryColor String @default("#1B3A5C")
  accentColor  String @default("#2E86AB")

  // Email settings
  microsoftClientId     String?
  microsoftTenantId     String?
  microsoftClientSecret String? @db.Text
  ssoEnabled            Boolean @default(false)
  emailDefaultCc        String?
  emailSignature        String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── USER ─────────────────────────────────────────────────────────────────────
model User {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  name        String
  email       String   @unique
  password    String?
  roleId      String?
  role        Role?    @relation(fields: [roleId], references: [id])
  active      Boolean  @default(true)
  maxDiscount Float    @default(10)
  microsoftId String?  @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  quotes                      Quote[]
  salesOrders                 SalesOrder[]
  purchaseOrders              PurchaseOrder[]
  sessions                    Session[]
  notifications               Notification[]
  connectedMicrosoftMailboxes MicrosoftConnection[]
  quoteComments               QuoteComment[]
  triggeredWorkflows          ApprovalWorkflow[]    @relation("WorkflowTriggerUser")
  approvalDecisions           QuoteApproval[]       @relation("ApprovalDecidedBy")
}

// ─── SESSION (Auth.js) ───────────────────────────────────────────────────────
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires      DateTime
}

// ─── CLIENT ──────────────────────────────────────────────────────────────────
model Client {
  id           String       @id @default(cuid())
  companyId    String
  company      Company      @relation(fields: [companyId], references: [id])
  name         String
  email        String?
  phone        String?
  website      String?
  industry     String?
  status       ClientStatus @default(PROSPECT)
  source       String?
  tags         String[]
  creditLimit  Float?
  paymentTerms String?
  notes        String?      @db.Text

  // Billing address
  billAddress String?
  billCity    String?
  billState   String?
  billZip     String?
  billCountry String?

  // Shipping address
  shipAddress String?
  shipCity    String?
  shipState   String?
  shipZip     String?
  shipCountry String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contacts      Contact[]
  quotes        Quote[]
  salesOrders   SalesOrder[]
  customPricing ClientCustomPrice[]
}

enum ClientStatus {
  ACTIVE
  PROSPECT
  INACTIVE
  LOST
}

// ─── CONTACT ─────────────────────────────────────────────────────────────────
model Contact {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id])
  firstName String
  lastName  String
  title     String?
  email     String?
  phone     String?
  mobile    String?
  isPrimary Boolean  @default(false)
  role      String?
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quotes Quote[]
}

// ─── VENDOR ──────────────────────────────────────────────────────────────────
model Vendor {
  id             String       @id @default(cuid())
  companyId      String
  company        Company      @relation(fields: [companyId], references: [id])
  name           String
  type           VendorType   @default(SUPPLIER)
  status         VendorStatus @default(ACTIVE)
  email          String?
  phone          String?
  website        String?
  address        String?
  paymentTerms   String?
  leadTimeDays   Int?
  notes          String?      @db.Text
  isDistributor  Boolean      @default(false)
  distributorKey String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  catalogItems   CatalogItem[]
  purchaseOrders PurchaseOrder[]
}

enum VendorType {
  SUPPLIER
  SUBCONTRACTOR
  PARTNER
  DISTRIBUTOR
}

enum VendorStatus {
  ACTIVE
  INACTIVE
  PREFERRED
}

// ─── CATALOG ITEM ─────────────────────────────────────────────────────────────
model CatalogItem {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  vendorId    String?
  vendor      Vendor?  @relation(fields: [vendorId], references: [id])
  name        String
  description String?  @db.Text
  sku         String?
  category    String?
  subcategory String?
  type        ItemType @default(PHYSICAL)
  msrp        Float    @default(0)
  cost        Float    @default(0)
  unit        String   @default("each")
  taxable     Boolean  @default(true)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  quoteLineItems    QuoteLineItem[]
  customPricing     ClientCustomPrice[]
  templateLineItems QuoteTemplateLineItem[]
}

enum ItemType {
  PHYSICAL
  SERVICE
  SUBSCRIPTION
  BUNDLE
}

// ─── CLIENT CUSTOM PRICING ───────────────────────────────────────────────────
model ClientCustomPrice {
  id            String      @id @default(cuid())
  clientId      String
  client        Client      @relation(fields: [clientId], references: [id])
  catalogItemId String
  catalogItem   CatalogItem @relation(fields: [catalogItemId], references: [id])
  price         Float
  createdAt     DateTime    @default(now())
}

// ─── QUOTE ───────────────────────────────────────────────────────────────────
model Quote {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id])
  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  quoteNumber         String
  version             Int            @default(1)
  parentId            String?
  isActive            Boolean        @default(true)
  status              QuoteStatus    @default(DRAFT)
  templateId          String?
  template            QuoteTemplate? @relation(fields: [templateId], references: [id])
  title               String?
  introText           String?        @db.Text
  terms               String?        @db.Text
  internalNotes       String?        @db.Text
  clientPoNumber      String?
  expiresAt           DateTime?
  sentAt              DateTime?
  viewedAt            DateTime?
  acceptedAt          DateTime?
  declinedAt          DateTime?
  declineReason       String?
  portalComment       String?        @db.Text
  portalCommentAt     DateTime?
  accessToken         String         @unique @default(cuid())
  taxRate             Float          @default(0)
  pendingEmailPayload Json?
  flagged             Boolean        @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lineItems  QuoteLineItem[]
  salesOrder SalesOrder?
  approvals  QuoteApproval[]
  comments   QuoteComment[]
}

enum QuoteStatus {
  DRAFT
  PENDING_APPROVAL
  SENT
  VIEWED
  ACCEPTED
  DECLINED
  EXPIRED
}

// ─── QUOTE LINE ITEM ─────────────────────────────────────────────────────────
model QuoteLineItem {
  id            String       @id @default(cuid())
  quoteId       String
  quote         Quote        @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  catalogItemId String?
  catalogItem   CatalogItem? @relation(fields: [catalogItemId], references: [id])

  section            String?
  sortOrder          Int                @default(0)
  name               String
  description        String?            @db.Text
  sku                String?
  quantity           Float              @default(1)
  unitPrice          Float              @default(0)
  cost               Float              @default(0)
  discount           Float              @default(0)
  taxable            Boolean            @default(true)
  isRecurring        Boolean            @default(false)
  recurringInterval  RecurringInterval?
  isOptional         Boolean            @default(false)
  optionalSelected   Boolean            @default(true)
  quantityAdjustable Boolean            @default(false)
  choiceGroup        String?
  isTextBlock        Boolean            @default(false)
  bundleName         String?
  bundleDisplayMode  String?            @default("COLLAPSED")
  isBundleHeader     Boolean            @default(false)
  createdAt          DateTime           @default(now())
}

enum RecurringInterval {
  MONTHLY
  QUARTERLY
  ANNUALLY
}

// ─── SALES ORDER ─────────────────────────────────────────────────────────────
model SalesOrder {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])
  quoteId   String  @unique
  quote     Quote   @relation(fields: [quoteId], references: [id])
  clientId  String
  client    Client  @relation(fields: [clientId], references: [id])
  userId    String
  user      User    @relation(fields: [userId], references: [id])

  soNumber       String
  clientPoNumber String?
  status         SalesOrderStatus @default(DRAFT)
  internalNotes  String? @db.Text
  clientNotes    String? @db.Text

  // Shipping
  shipAddress String?
  shipCity    String?
  shipState   String?
  shipZip     String?
  shipCountry String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchaseOrders PurchaseOrder[]
  lineItems      SOLineItem[]
}

enum SalesOrderStatus {
  DRAFT
  READY_TO_INVOICE
  INVOICED
  READY_TO_ORDER
  PARTS_ORDERED
  READY_TO_CLOSEOUT
  CLOSED
}

// ─── SO LINE ITEM ─────────────────────────────────────────────────────────────
model SOLineItem {
  id                String             @id @default(cuid())
  salesOrderId      String
  salesOrder        SalesOrder         @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  name              String
  description       String?            @db.Text
  sku               String?
  section           String?
  quantity          Float              @default(1)
  unitPrice         Float              @default(0)
  cost              Float              @default(0)
  discount          Float              @default(0)
  taxable           Boolean            @default(true)
  isRecurring       Boolean            @default(false)
  recurringInterval RecurringInterval?
  serialNumber      String?
  isTextBlock       Boolean            @default(false)
  bundleName        String?
  bundleDisplayMode String?            @default("COLLAPSED")
  isBundleHeader    Boolean            @default(false)
  sortOrder         Int                @default(0)
  createdAt         DateTime           @default(now())

  fulfillingPOLineItems POLineItem[]
}

// ─── PURCHASE ORDER ──────────────────────────────────────────────────────────
model PurchaseOrder {
  id           String      @id @default(cuid())
  companyId    String
  company      Company     @relation(fields: [companyId], references: [id])
  salesOrderId String?
  salesOrder   SalesOrder? @relation(fields: [salesOrderId], references: [id])
  vendorId     String
  vendor       Vendor      @relation(fields: [vendorId], references: [id])
  userId       String
  user         User        @relation(fields: [userId], references: [id])

  poNumber      String
  status        POStatus  @default(DRAFT)
  paymentType   String    @default("Net30")
  internalNotes String?   @db.Text
  sentAt        DateTime?
  expectedAt    DateTime?
  receivedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lineItems POLineItem[]
  shipments POShipment[]
}

enum POStatus {
  DRAFT
  PARTS_ORDERED
  RECEIVED
  ON_HOLD
  BACKORDERED
  CANCELLED
}

// ─── PO LINE ITEM ─────────────────────────────────────────────────────────────
model POLineItem {
  id                 String        @id @default(cuid())
  purchaseOrderId    String
  purchaseOrder      PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  sourceSOLineItemId String?
  sourceSOLineItem   SOLineItem?   @relation(fields: [sourceSOLineItemId], references: [id])
  name               String
  description        String?       @db.Text
  sku                String?
  quantity           Float         @default(1)
  unitCost           Float         @default(0)
  serialNumber       String?
  received           Boolean       @default(false)
  sortOrder          Int           @default(0)
  createdAt          DateTime      @default(now())
}

// ─── PO SHIPMENT ─────────────────────────────────────────────────────────────
model POShipment {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  carrier         String?
  trackingNumber  String?
  shippedAt       DateTime?
  notes           String?
  createdAt       DateTime      @default(now())
}

// ─── QUOTE TEMPLATE ───────────────────────────────────────────────────────
model QuoteTemplate {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  description String?  @db.Text
  introText   String?  @db.Text
  terms       String?  @db.Text
  expiryDays  Int      @default(30)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lineItems QuoteTemplateLineItem[]
  quotes    Quote[]
}

model QuoteTemplateLineItem {
  id            String        @id @default(cuid())
  templateId    String
  template      QuoteTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  catalogItemId String?
  catalogItem   CatalogItem?  @relation(fields: [catalogItemId], references: [id])

  section            String?
  sortOrder          Int                @default(0)
  name               String
  description        String?            @db.Text
  sku                String?
  quantity           Float              @default(1)
  unitPrice          Float              @default(0)
  cost               Float              @default(0)
  discount           Float              @default(0)
  taxable            Boolean            @default(true)
  isRecurring        Boolean            @default(false)
  recurringInterval  RecurringInterval?
  isOptional         Boolean            @default(false)
  optionalSelected   Boolean            @default(true)
  quantityAdjustable Boolean            @default(false)
  choiceGroup        String?
  isTextBlock        Boolean            @default(false)
  bundleName         String?
  bundleDisplayMode  String?            @default("COLLAPSED")
  isBundleHeader     Boolean            @default(false)
  createdAt          DateTime           @default(now())
}

// ─── DISTRIBUTOR INTEGRATION ─────────────────────────────────────────────────
model DistributorIntegration {
  id          String         @id @default(cuid())
  companyId   String
  company     Company        @relation(fields: [companyId], references: [id])
  distributor DistributorKey
  enabled     Boolean        @default(false)
  priority    Int            @default(0)

  // Credential fields — not every distributor uses every field
  apiKey       String?
  clientId     String?
  clientSecret String?
  partnerId    String?
  accessToken  String? @db.Text
  refreshToken String? @db.Text

  lastSyncedAt   DateTime?
  lastTestStatus String?
  lastTestedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, distributor])
}

enum DistributorKey {
  INGRAM_MICRO
  TD_SYNNEX
  DH
  AMAZON_BUSINESS
}

// ─── APPROVAL WORKFLOWS ───────────────────────────────────────────────────
model ApprovalWorkflow {
  id             String              @id @default(cuid())
  companyId      String
  company        Company             @relation(fields: [companyId], references: [id])
  name           String
  active         Boolean             @default(true)
  triggerType    ApprovalTriggerType
  thresholdValue Float?
  triggerUserId  String?
  triggerUser    User?               @relation("WorkflowTriggerUser", fields: [triggerUserId], references: [id])
  requiredRoleId String
  requiredRole   Role     @relation(fields: [requiredRoleId], references: [id])
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  approvals QuoteApproval[]
}

enum ApprovalTriggerType {
  TOTAL_THRESHOLD
  DISCOUNT_THRESHOLD
  SPECIFIC_USER
}

model QuoteApproval {
  id               String           @id @default(cuid())
  quoteId          String
  quote            Quote            @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  workflowId       String
  workflow         ApprovalWorkflow @relation(fields: [workflowId], references: [id])
  status           ApprovalStatus   @default(PENDING)
  approvedByUserId String?
  approvedByUser   User?            @relation("ApprovalDecidedBy", fields: [approvedByUserId], references: [id])
  decidedAt        DateTime?
  reason           String?
  createdAt        DateTime         @default(now())

  @@unique([quoteId, workflowId])
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── MICROSOFT CONNECTIONS ────────────────────────────────────────────────
model MicrosoftConnection {
  id                String   @id @default(cuid())
  companyId         String
  company           Company  @relation(fields: [companyId], references: [id])
  label             String
  email             String
  accessToken       String   @db.Text
  refreshToken      String   @db.Text
  connectedByUserId String?
  connectedByUser   User?    @relation(fields: [connectedByUserId], references: [id])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  usedAsQuoteSenderBy CompanySettings[]

  @@unique([companyId, email])
}

// ─── QUOTE COMMENTS ─────────────────────────────────────────────────────
model QuoteComment {
  id           String   @id @default(cuid())
  quoteId      String
  quote        Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  authorType   String // "INTERNAL" | "CLIENT"
  authorUserId String?
  authorUser   User?    @relation(fields: [authorUserId], references: [id])
  authorName   String
  message      String   @db.Text
  createdAt    DateTime @default(now())
}

// ─── NOTIFICATION ─────────────────────────────────────────────────────────
model Notification {
  id        String           @id @default(cuid())
  companyId String
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  message   String
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
}

enum NotificationType {
  QUOTE_VIEWED
  QUOTE_APPROVED
  QUOTE_LOST
  SO_READY_TO_INVOICE
  SO_READY_TO_ORDER
  SO_READY_TO_CLOSEOUT
}

// ─── ROLE ────────────────────────────────────────────────────────────────
model Role {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  name        String
  // Higher rank = more senior, used for "X or higher" comparisons (e.g.
  // approval workflows, who can decide a pending approval)
  rank        Int      @default(0)
  // Every permission toggle lives here as one flexible object instead of a
  // dedicated column per permission, so adding new permissions later never
  // needs a migration. Shape (all booleans unless noted):
  // {
  //   pages: { clients, catalog, vendors, quotes, settings, salesOrders, purchaseOrders },
  //   quotes: { create, edit, delete, changeStatus, approve, sendEmail, viewAllUsersQuotes },
  //   clients: { create, edit, delete, viewAllClients },
  //   salesOrders: { create, edit, delete, changeStatus, generatePO },
  //   purchaseOrders: { create, edit, delete, changeStatus, send },
  //   settingsSections: { company, users, quotes, approvalWorkflows, notifications, integrations },
  //   maxDiscount: number
  // }
  permissions Json
  // System roles are the 5 starter roles created during migration — kept
  // distinguishable so we can decide later whether to protect them from
  // deletion (e.g. don't let the last Admin-equivalent role be deleted)
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users             User[]
  approvalWorkflows ApprovalWorkflow[]

  @@unique([companyId, name])
}
